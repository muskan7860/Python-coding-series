import boto3
from datetime import datetime, timezone
from botocore.exceptions import ClientError
from config import AWS_REGION, STOPPED_DAYS_THRESHOLD
from logger import setup_logger

logger = setup_logger()
ec2 = boto3.client("ec2", region_name=AWS_REGION)

def get_stopped_instances():
    stopped_instances = []

    try:
        paginator = ec2.get_paginator("describe_instances")
        pages = paginator.paginate(
            Filters=[{"Name": "instance-state-name", "Values": ["stopped"]}]
        )

        for page in pages:
            for reservation in page["Reservations"]:
                for instance in reservation["Instances"]:
                    launch_time = instance["LaunchTime"]
                    days_stopped = (datetime.now(timezone.utc) - launch_time).days

                    if days_stopped >= STOPPED_DAYS_THRESHOLD:
                        stopped_instances.append({
                            "InstanceId": instance["InstanceId"],
                            "InstanceType": instance["InstanceType"],
                            "DaysStopped": days_stopped
                        })

        logger.info("Fetched stopped EC2 instances successfully")

    except ClientError as e:
        logger.error(f"AWS error while fetching EC2 data: {e}")
    except Exception as e:
        logger.error(f"Unexpected error: {e}")

    return stopped_instances
