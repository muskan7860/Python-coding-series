import boto3
from botocore.exceptions import ClientError
from logger import get_logger

logger = get_logger()
ec2 = boto3.client("ec2")

def ec2_health():
    try:
        response = ec2.describe_instance_status(IncludeAllInstances=True)
        return [
            {
                "InstanceId": i["InstanceId"],
                "State": i["InstanceState"]["Name"]
            }
            for i in response["InstanceStatuses"]
        ]
    except ClientError as e:
        logger.error(f"AWS EC2 error: {e}")
        return []
📌 main.py
from fastapi import FastAPI, HTTPException
from system_metrics import get_system_metrics
from aws_metrics import ec2_health

app = FastAPI(title="Infra Health API")

@app.get("/health/system")
def system_health():
    return get_system_metrics()

@app.get("/health/ec2")
def ec2_status():
    data = ec2_health()
    if not data:
        raise HTTPException(status_code=500, detail="EC2 data unavailable")
    return data
